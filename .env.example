# Copy to .env and fill in values before deploying
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret-in-production

# PostgreSQL connection string from Neon (https://neon.tech)
# Leave unset to fall back to SQLite for local dev
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Comma-separated list of allowed frontend origins (set after you know your Vercel URL)
# Use * to allow all (dev only)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ── SMS / OTP ────────────────────────────────────────────────────────────────
# MOCK_SMS=true  → prints OTP to the terminal (default for local dev, no SMS sent)
# MOCK_SMS=false → sends a real SMS via SMS_PROVIDER
MOCK_SMS=true

# SMS_PROVIDER options: twilio | fast2sms
SMS_PROVIDER=twilio

# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+1XXXXXXXXXX

# Fast2SMS — good for Indian numbers (https://fast2sms.com)
# FAST2SMS_API_KEY=your_api_key

# Railway injects PORT automatically — do not set it manually on Railway
# PORT=5000
